                "ENSEMBLE_MODEL_PATH": "models/ensemble_v2",
                "BERT_VALIDATOR_MODEL": "models/rubert-base-cased-conversational_ner-v3",
                "GPU_DEVICE": "auto"
            }
        }
    ]
